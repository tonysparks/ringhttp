// TLS + ALPN integration tests for ringhttp.
//
// Starts ringhttp with tlsCertFile/tlsKeyFile set (self-signed cert in test/certs/).
// Verifies that:
//   - A curl client with --http2 (ALPN) negotiates h2 and gets a 200
//   - A curl client without --http2 falls back to http/1.1 and gets a 200
//   - A raw TLS connection that offers only "http/1.1" in ALPN gets HTTP/1.1
//
// Uses the std/http/http Http client (which sets CURLOPT_HTTP_VERSION_2_0
// when priorKnowledge=false, letting ALPN drive negotiation) and the libcurl
// @foreign bindings for raw control.

import "std/mem"
import "std/assert"
import "std/string"
import "std/string/builder"
import "std/map"
import "std/thread"
import "std/thread/barrier"
import "std/libc"

import "std/http/http" as stdhttp

import "http_ring"

// ---------------------------------------------------------------------------
// Test server — TLS on port 9595
// ---------------------------------------------------------------------------

const TLS_TEST_PORT: u16 = 9595_u16

// Absolute paths to the test cert/key generated by OpenSSL.
//const TLS_CERT = "/build/test/certs/cert.pem"
//const TLS_KEY  = "/build/test/certs/key.pem"
const TLS_CERT = "../test/certs/cert.pem"
const TLS_KEY  = "../test/certs/key.pem"


func TlsHelloHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.addHeaderStr("content-type", "text/plain")
    ctx.response.body.append("tls-hello")
    return 1
}

func TlsEchoHandler(ctx: *RequestHandlerContext) : i32 {
    var req = ctx.request
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.appendStrn(req.body.buffer, req.body.length)
    return 1
}

struct TlsTestServer {
    config:  HttpConfig
    barrier: Barrier
}

var gTlsServer: TlsTestServer
var gTlsServerReady = false

func TlsServerThread(arg: *void) : i32 {
    var ts = arg as (*TlsTestServer)
    var server = HttpServer{}
    server.init(&ts.config)
    server.addHttpController(HttpMethod.GET,  "/hello", null,
        HttpController{.callback = TlsHelloHandler})
    server.addHttpController(HttpMethod.POST, "/echo",  null,
        HttpController{.callback = TlsEchoHandler})
    ts.barrier.wait()
    server.start()
    defer server.close()
    return 0
}

func ensureTlsServer() {
    if(gTlsServerReady) { return; }

    gTlsServer.config = HttpConfig{
        .allocator             = defaultAllocator,
        .port                  = TLS_TEST_PORT,
        .numThreads            = 2,
        .maxPoolSize           = 32,
        .keepAliveTimeoutInSec = 10,
        .isLogEnabled          = false,
        .tlsCertFile           = TLS_CERT,
        .tlsKeyFile            = TLS_KEY,
    }
    gTlsServer.barrier.init(2)

    var thread = Thread{}
    assert(thread.create(TlsServerThread, &gTlsServer) == ThreadStatus.SUCCESS)
    gTlsServer.barrier.wait()
    ThreadSleepMSec(500)  // give TLS init + worker thread startup a moment
    gTlsServerReady = true
}

func tlsUrl(path: *const char, buf: *char, bufLen: i32) : *const char {
    snprintf(buf, bufLen as (usize), "https://127.0.0.1:%d%s",
        TLS_TEST_PORT as (i32), path)
    return buf
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

// HTTP/2 over TLS (ALPN negotiates h2).
@test("tls_h2_get")
func testTlsH2Get() {
    ensureTlsServer()

    // http2=true → curl offers h2 via ALPN; verifySsl=false for self-signed test cert
    var opts = stdhttp::HttpOptions{ .http2 = true, .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/hello", urlBuf, 128)
    assert(client.get(url, &resp))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-hello"))
}

// HTTP/1.1 over TLS (ALPN negotiates http/1.1 because we don't set http2=true).
@test("tls_h1_get")
func testTlsH1Get() {
    ensureTlsServer()

    var opts = stdhttp::HttpOptions{ .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/hello", urlBuf, 128)
    assert(client.get(url, &resp))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-hello"))
}

// POST over TLS with ALPN h2.
@test("tls_h2_post")
func testTlsH2Post() {
    ensureTlsServer()

    var opts = stdhttp::HttpOptions{ .http2 = true, .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/echo", urlBuf, 128)
    assert(client.post(url, &resp, $"tls-payload"))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-payload"))
}
