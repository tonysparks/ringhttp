// ---------------------------------------------------------------
// Shared HTTP methods
// Backend provides: queueSend, closeSession, rearmTimeout, sendWebSocketFrame
// ---------------------------------------------------------------

internal func (this: *WorkerThread) handleAccept(clientSocket: i32) : *SessionContext {
    var index = this.sessions.alloc()
    if(index < 0) {
        Warn("SessionContext pool exhausted, dropping connection\n")
        return null
    }

    var session = this.sessions.get(index)
    assert(session != null)

    session.begin(clientSocket)
    return session
}

internal func (this: *WorkerThread) serverError(
    requestContext: *RequestHandlerContext,
    status: Status
) {
    var request  = requestContext.request
    var response = requestContext.response

    Error("Internal error: %s %.*s\n",
        HttpMethodAsStr(request.method),
        request.path.length, request.path.buffer
    )

    response.status = 500
    if(this.server.errorHandler.__this) {
        this.server.errorHandler.handle(requestContext, status)
    }
    else {
        response.type = ResponseType.BODY
        response.body.append("Internal Error handling the request.")
    }
}

internal func (this: *WorkerThread) server404(
    requestContext: *RequestHandlerContext,
    status: Status
) {
    var request  = requestContext.request
    var response = requestContext.response

    response.status = 404
    if(this.server.notFoundHandler.__this) {
        this.server.notFoundHandler.handle(requestContext, status)
    }
    else {
        response.type = ResponseType.BODY
        response.body.append("No route bound.")
    }
}

func (this: *WorkerThread) writeAllowHeader(
    requestContext: *RequestHandlerContext,
    allowedMethods: i32
) {
    var response = requestContext.response
    var allowBuf = requestContext.allocator.alloc(128) as (*char)
    var allowLen = 0
    // OPTIONS is always allowed if we are here.
    var allMethods = allowedMethods | (1 << HttpMethod.OPTIONS as (i32))
    for(var m = 1; m < MAX_METHODS; m += 1) {
        if(allMethods & (1 << m)) {
            if(allowLen > 0) {
                allowBuf[allowLen] = ','
                allowBuf[allowLen + 1] = ' '
                allowLen += 2
            }
            var methodName = HttpMethodAsStr(m as (HttpMethod))
            var methodLen = methodName.length()
            memcpy(allowBuf + allowLen, methodName, methodLen as (usize))
            allowLen += methodLen
        }
    }
    response.addHeader($"Allow", String{.buffer = allowBuf, .length = allowLen})
}

// RFC 7231 §4.3.7: OPTIONS auto-response — 200 with an Allow header.
// Used when no handler is registered for OPTIONS on the given path.
internal func (this: *WorkerThread) serverOptions(
    requestContext: *RequestHandlerContext,
    allowedMethods: i32
) {
    var response = requestContext.response

    response.status = 200
    response.type   = ResponseType.BODY

    this.writeAllowHeader(requestContext, allowedMethods)
    response.addHeader($"Content-Length", $"0")
}

// RFC 7231 §6.5.5: 405 Must Not Allowed MUST include an Allow header listing
// the methods that are valid for the requested resource.
internal func (this: *WorkerThread) server405(
    requestContext: *RequestHandlerContext,
    allowedMethods: i32
) {
    var request  = requestContext.request
    var response = requestContext.response

    response.status = 405
    response.type   = ResponseType.BODY
    response.body.append("Method Not Allowed\n")

    this.writeAllowHeader(requestContext, allowedMethods)
}


internal func (this: *WorkerThread) send100Continue(
    context: *SessionContext
): Status {
    var httpRequest = HttpRequest{}
    var requestContext = RequestHandlerContext {
        .allocator = &context.requestAllocator.allocator,
        .request   = &httpRequest,
        .response  = &context.response,
        .userData  = null,
        .match     = null
    }

    var response = requestContext.response
    response.status = 100
    response.type   = ResponseType.BODY

    return this.queueSend(context)
}

internal func (this: *WorkerThread) sendBadRequest(
    context: *SessionContext,
    status:  Status
): Status {
    var httpRequest = HttpRequest{}
    var requestContext = RequestHandlerContext {
        .allocator = &context.requestAllocator.allocator,
        .request   = &httpRequest,
        .response  = &context.response,
        .userData  = null,
        .match     = null
    }

    var response = requestContext.response
    response.status = 400
    response.type   = ResponseType.BODY

    switch(status) {
        case Status.ERROR_INVALID_REQUEST_PATH_EXCEEDED_LIMIT:
            response.status = 414
            response.body.append(
                "Request URI exceeds the maximum of %d bytes\n",
                this.config.maxHttpRequestLineSizeInBytes
            )
            break
        case Status.ERROR_INVALID_HEADER_EXCEEDED_LIMIT:
            response.body.append(
                "Request exceeded the max request limit of %d bytes for headers\n",
                this.config.maxHttpHeaderSizeInBytes
            )
            break
        case Status.ERROR_INVALID_BODY_EXCEEDED_LIMIT:
            response.status = 413
            response.body.append(
                "Request exceeded the max request limit of %d bytes for body\n",
                this.config.maxHttpBodySizeInBytes
            )
            break
        case Status.ERROR_UNKNOWN_BODY_LENGTH:
            response.status = 411
            response.body.append("Missing Content-Length or Transfer-Encoding\n")
            break
        case Status.ERROR_PARSING_HTTP_REQUEST:
            response.status = 422
            response.body.append("Unprocessable request body\n")
            break
        case Status.ERROR_WEB_SOCKET_SECURITY_KEY:
            response.body.append("Missing or invalid Sec-WebSocket-Key\n")
            break
        case Status.ERROR_UNSUPPORTED_UPGRADE_PROTOCOL:
            response.status = 426
            response.body.append("The requested protocol upgrade is not supported\n")
            break
        case Status.ERROR_MISSING_HOST_HEADER:
            response.body.append("HTTP/1.1 requests must include a Host header\n")
            break
        case Status.ERROR_HTTP_VERSION_NOT_SUPPORTED:
            response.status = 505
            response.body.append("HTTP Version Not Supported\n")
            break
        case Status.ERROR_CONFLICTING_BODY_HEADERS:
            response.body.append("Request must not carry both Transfer-Encoding and Content-Length\n")
            break
        case Status.ERROR_CONFLICTING_CONTENT_LENGTH:
            response.body.append("Duplicate Content-Length headers with differing values\n")
            break
        case Status.ERROR_UNSUPPORTED_REQUEST_METHOD:
            response.status = 501
            response.body.append("Method not implemented\n")
            break
        case Status.ERROR_EXPECT_FAILED:
            response.status = 417
            response.body.append("Expectation Failed\n")
            break
        case Status.ERROR_WEB_SOCKET_MISSING_CONNECTION:
            response.body.append("Upgrade request must include 'Connection: upgrade'\n")
            break
        default:
            response.body.append("Bad request\n")
            break
    }

    return this.queueSend(context)
}

internal func (this: *WorkerThread) sendServerError(
    session: *SessionContext,
    status:  Status
): Status {
    var httpRequest = HttpRequest{}
    var requestContext = RequestHandlerContext {
        .allocator = &session.requestAllocator.allocator,
        .request   = &httpRequest,
        .response  = &session.response,
        .userData  = null,
        .match     = null
    }
    this.serverError(&requestContext, status)
    return this.queueSend(session)
}

internal func (this: *WorkerThread) handlePartialHttpRequest(
    request:   *SessionContext,
    bytesRead: i32
): Status {

    var connection = &request.connection
    var readBuffer = &connection.readBuffer

    readBuffer.length += bytesRead

    var buffer = readBuffer.toString()
    if(request.requestLineIndex < 1) {
        request.requestLineIndex = buffer.endIndexOf($"\r\n")
        if(request.requestLineIndex < 0) {
            if(readBuffer.remaining() < this.config.maxHttpRequestLineSizeInBytes) {
                readBuffer.reserve(readBuffer.capacity + this.config.maxHttpRequestLineSizeInBytes as (i32))
            }

            Debug("RequestLine not fully read, waiting for more data: %d\n", connection.handle())
            return Status.PARTIAL_REQUEST_DISPATCHING_READ
        }

        if(request.requestLineIndex > this.config.maxHttpRequestLineSizeInBytes) {
            return Status.ERROR_INVALID_REQUEST_PATH_EXCEEDED_LIMIT
        }
    }

    if(request.headerIndex < 1) {
        request.headerIndex = buffer.endIndexOf($"\r\n\r\n")
        if(request.headerIndex < 0) {
            if(readBuffer.remaining() < this.config.maxHttpHeaderSizeInBytes) {
                readBuffer.reserve(readBuffer.capacity + this.config.maxHttpHeaderSizeInBytes as (i32))
            }

            Debug("Headers not fully read, waiting for more data: %d\n", connection.handle())
            return Status.PARTIAL_REQUEST_DISPATCHING_READ
        }

        var headerSize = request.headerIndex - request.requestLineIndex
        if(headerSize > this.config.maxHttpHeaderSizeInBytes) {
            return Status.ERROR_INVALID_HEADER_EXCEEDED_LIMIT
        }

        request.bodyIndex = request.headerIndex
    }

    var parser = HttpParser{}
    parser.init(&request.requestAllocator.allocator)

    var input = String {
        .buffer = readBuffer.buffer,
        .length = request.headerIndex
    }

    var httpRequest = &request.request
    var ok = parser.parse(input, httpRequest)
    if(ok != ParseStatus.OK) {
        return Status.ERROR_PARSING_HTTP_REQUEST
    }

    // RFC 7231 §4.1: unrecognised request method → 501 Not Implemented.
    if(httpRequest.method == HttpMethod.INVALID) {
        return Status.ERROR_UNSUPPORTED_REQUEST_METHOD
    }

    // RFC 7230 §3.3.2: duplicate Content-Length with differing values → 400.
    if((httpRequest.flags & HttpFlags.CONFLICTING_CONTENT_LENGTH) != 0) {
        return Status.ERROR_CONFLICTING_CONTENT_LENGTH
    }

    // RFC 7230 §2.6: reject unsupported HTTP versions.
    if(!httpRequest.version.equals($"HTTP/1.1") && !httpRequest.version.equals($"HTTP/1.0")) {
        return Status.ERROR_HTTP_VERSION_NOT_SUPPORTED
    }

    // RFC 7230 §5.4: HTTP/1.1 requests MUST carry a Host header.
    if(httpRequest.version.equals($"HTTP/1.1")) {
        var host = httpRequest.getHeaderValue($"Host")
        if(host.empty()) {
            return Status.ERROR_MISSING_HOST_HEADER
        }
    }

    // RFC 7231 §5.1.1: an unrecognised Expect value MUST be rejected with 417.
    if((httpRequest.flags & HttpFlags.EXPECT_UNKNOWN) != 0) {
        return Status.ERROR_EXPECT_FAILED
    }

    // RFC 7230 §6.7: an Upgrade request MUST also have Connection: upgrade.
    if((httpRequest.flags & HttpFlags.WEB_SOCKET_PROTOCOL) != 0 &&
       (httpRequest.flags & HttpFlags.UPGRADE_REQUEST) == 0) {
        return Status.ERROR_WEB_SOCKET_MISSING_CONNECTION
    }

    if(httpRequest.flags & HttpFlags.CHUNKED_ENCODING) {
        // RFC 7230 §3.3.3: receiving both TE and Content-Length is a protocol error.
        if((httpRequest.flags & HttpFlags.CONTENT_LENGTH_PROVIDED) != 0) {
            return Status.ERROR_CONFLICTING_BODY_HEADERS
        }
        httpRequest.bodyLength = 0

        var status = parser.parseChunk(readBuffer.toString().substring(request.headerIndex), httpRequest)
        if(status == ParseStatus.CHUNK_INCOMPLETE) {
            return Status.PARTIAL_REQUEST_DISPATCHING_READ
        }
        if(status != ParseStatus.OK) {
            return Status.ERROR_PARSING_HTTP_REQUEST
        }
    }
    else if(httpRequest.flags & HttpFlags.CONTENT_LENGTH_PROVIDED) {
        var bodyLength = httpRequest.bodyLength
        if(this.config.maxHttpBodySizeInBytes > 0 && bodyLength > this.config.maxHttpBodySizeInBytes) {
            return Status.ERROR_INVALID_BODY_EXCEEDED_LIMIT
        }

        if(readBuffer.length - request.headerIndex < bodyLength) {
            if(readBuffer.remaining() < 1 * MiB) {
                readBuffer.reserve(readBuffer.capacity + 1 * MiB as (i32))
            }

            // RFC 7231 §5.1.1: send 100 Continue so the client will send the body.
            // Guard with SENT_CONTINUE to avoid re-sending on each partial read.
            if((httpRequest.flags & HttpFlags.EXPECT_CONTINUE) &&
               !(httpRequest.flags & HttpFlags.SENT_CONTINUE)) {

                httpRequest.flags |= HttpFlags.SENT_CONTINUE
                return Status.CONTINUE_SEND
            }

            return Status.PARTIAL_REQUEST_DISPATCHING_READ
        }
    }
    else {
        var body = readBuffer.toString().substring(request.headerIndex)
        if(!body.empty()) {
            return Status.ERROR_UNKNOWN_BODY_LENGTH
        }
    }

    return Status.OK
}

internal func (this: *WorkerThread) handleHttpRequest(
    request: *SessionContext
): Status {

    var requestAllocator = &request.requestAllocator.allocator
    var connection = &request.connection

    var buffer = &connection.readBuffer
    Debug("Handling HTTP request for socket: %d\n", connection.handle())

    var parser = HttpParser{}
    parser.init(requestAllocator)

    var input = StringInit(buffer.buffer, buffer.length).substring(request.bodyIndex)
    var httpRequest = &request.request

    if(httpRequest.flags & HttpFlags.CHUNKED_ENCODING) {
        input = httpRequest.body.chunkData.toString()
    }

    var ok = parser.parseBody(input, httpRequest)
    if(ok != ParseStatus.OK) {
        return Status.ERROR_PARSING_HTTP_REQUEST
    }

    // RFC 7230 §6.3: HTTP/1.0 is close-by-default; HTTP/1.1 is keep-alive-by-default.
    var isHttp10 = httpRequest.version.equals($"HTTP/1.0")
    var keepAliveOptIn = (httpRequest.flags & HttpFlags.KEEP_ALIVE_REQUESTED) != 0
    connection.disableKeepAlive = (httpRequest.flags & HttpFlags.DISABLE_KEEP_ALIVE) != 0 ||
                                  (isHttp10 && !keepAliveOptIn)

    if(httpRequest.method == HttpMethod.GET) {
        if(httpRequest.path.startsWith(this.server.config.publicServerPath)) {
            return this.handleFileRequest(request, httpRequest)
        }
    }

    var requestContext = RequestHandlerContext {
        .allocator    = requestAllocator,
        .request      = httpRequest,
        .response     = &request.response,
        .userData     = null,
        .match        = null,
        .startTime    = request.lastRequestTime,
        .sessionIndex = request.index
    }

    // Pre-dispatch filters — each may block the request by returning 0.
    // The blocking filter is responsible for writing its own response.
    var blocked = false
    for(var i = 0; i < this.server.filterHandlers.size(); i += 1) {
        if(this.server.filterHandlers.get(i).handleFilter(&requestContext) == 0) {
            blocked = true
            break
        }
    }

    var requestMatch: RouteMatch;
    if(!blocked) {
        if(!this.server.router.match(httpRequest.method, httpRequest.path, &requestMatch)) {
            var allowed = this.server.router.allowedMethods(&httpRequest.path)
            // RFC 7231 §4.3.7: OPTIONS with no registered handler auto-responds with Allow.
            // "OPTIONS *" is a server-wide capabilities query — allow on any known path.
            if(httpRequest.method == HttpMethod.OPTIONS) {
                this.serverOptions(&requestContext, allowed)
            } else if(allowed != 0) {
                this.server405(&requestContext, allowed)
            } else {
                this.server404(&requestContext, Status.ERROR_NO_ROUTE_FOUND)
            }
        }
        else {
            var handler = requestMatch.handler
            requestContext.userData = handler.userData
            requestContext.match    = &requestMatch

            switch(handler.type) {
                case RequestHandlerType.HTTP_REQUEST: {
                    if(handler.controller.callback(&requestContext) != 1) {
                        this.serverError(&requestContext, Status.ERROR_CONTROLLER_CALLBACK_ERROR)
                    }
                    break
                }
                case RequestHandlerType.SSE_STREAM: {
                    if(httpRequest.method != HttpMethod.GET) {
                        this.serverError(&requestContext, Status.ERROR_CONTROLLER_CALLBACK_ERROR)
                        break
                    }
                    return this.handleSseSetup(request, httpRequest, &requestContext)
                }
                case RequestHandlerType.WEB_SOCKET: {
                    if(httpRequest.method != HttpMethod.GET) {
                        this.serverError(&requestContext, Status.ERROR_CONTROLLER_CALLBACK_ERROR)
                        break
                    }

                    if(httpRequest.flags & HttpFlags.UPGRADE_REQUEST) {
                        if(!(httpRequest.flags & HttpFlags.WEB_SOCKET_PROTOCOL)) {
                            return this.sendBadRequest(request, Status.ERROR_UNSUPPORTED_UPGRADE_PROTOCOL)
                        }

                        return this.handleWebSocketUpgrade(
                            request,
                            httpRequest,
                            &requestContext
                        )
                    }

                    // Non-upgrade GET to a WebSocket-only endpoint
                    requestContext.response.status = 400
                    requestContext.response.type   = ResponseType.BODY
                    requestContext.response.body.append("WebSocket upgrade required\n")
                    break
                }
                default: {
                    assert(false)
                }
            }
        }
    }

    // Post-dispatch handlers — always called for HTTP requests (blocked or not).
    for(var i = 0; i < this.server.postHandlers.size(); i += 1) {
        this.server.postHandlers.get(i).postHandle(&requestContext)
    }

    var elapsed = SystemTimeMSec() - request.lastRequestTime
    var httpReq = &request.request
    Info("%s %.*s %d %.0fms\n",
        HttpMethodAsStr(httpReq.method),
        httpReq.path.length, httpReq.path.buffer,
        request.response.status,
        elapsed
    )

    return this.queueSend(request)
}

internal func (this: *WorkerThread) handleWebSocketUpgrade(
    context:        *SessionContext,
    httpRequest:    *HttpRequest,
    requestContext: *RequestHandlerContext
): Status {

    var secKey = httpRequest.getHeaderValue($"Sec-WebSocket-Key")
    if(secKey.empty()) {
        return Status.ERROR_WEB_SOCKET_SECURITY_KEY
    }

    var keyBuffer = [128]char;
    var keyString = StringBufferInit(keyBuffer, 128)
    keyString.append("%.*s%s", secKey.length, secKey.buffer, WEB_SOCKET_MAGIC)

    var hashResult:[SHA1_BLOCK_SIZE]u8;
    var ctx: sha1_ctx;

    sha1_init(&ctx)
    sha1_update(&ctx, keyString.cStr() as (*u8), keyString.length)
    sha1_final(&ctx, hashResult)

    var keyAccept = context.requestAllocator.alloc(sizeof(:u8) * 64) as (*u8)
    var bytesEncoded = base64_encode(hashResult, keyAccept, SHA1_BLOCK_SIZE, 0)

    var response = &context.response
    response.status = 101
    response.type   = ResponseType.BODY
    response.addHeaderStr("Upgrade", "websocket")
    response.addHeaderStr("Connection", "Upgrade")
    response.addHeader(
        StringInit("Sec-WebSocket-Accept"),
        String{.buffer = keyAccept as (*const char), .length = bytesEncoded as (i32)}
    )

    context.socketSession.worker   = this
    context.socketSession.userData = requestContext.userData
    context.socketSession.allocator = requestContext.allocator

    var requestMatch = requestContext.match
    assert(requestMatch.handler.type == RequestHandlerType.WEB_SOCKET)
    context.socketHandler = requestMatch.handler.webSocket
    context.state         = SessionState.WEB_SOCKET_UPGRADED
    context.isWebSocket   = true

    var connection = &context.connection
    var readBuffer = &connection.readBuffer
    readBuffer.clear()

    var elapsed = SystemTimeMSec() - context.lastRequestTime
    Info("%s %.*s %d %.0fms\n",
        HttpMethodAsStr(httpRequest.method),
        httpRequest.path.length, httpRequest.path.buffer,
        context.response.status,
        elapsed
    )

    return this.queueSend(context)
}

internal func (this: *WorkerThread) handleSseSetup(
    context:        *SessionContext,
    httpRequest:    *HttpRequest,
    requestContext: *RequestHandlerContext
): Status {

    var response = &context.response
    response.status = 200
    response.type   = ResponseType.SSE

    context.sseSession.worker    = this
    context.sseSession.context   = context
    context.sseSession.userData  = requestContext.userData
    context.sseSession.allocator = requestContext.allocator

    var requestMatch = requestContext.match
    assert(requestMatch.handler.type == RequestHandlerType.SSE_STREAM)
    context.sseHandler = requestMatch.handler.sseController
    context.state      = SessionState.SSE_UPGRADED
    context.isSse      = true

    var readBuffer = &context.connection.readBuffer
    readBuffer.clear()

    var elapsed = SystemTimeMSec() - context.lastRequestTime
    Info("%s %.*s %d %.0fms\n",
        HttpMethodAsStr(httpRequest.method),
        httpRequest.path.length, httpRequest.path.buffer,
        context.response.status,
        elapsed
    )

    return this.queueSend(context)
}

internal func (this: *WorkerThread) handleFileRequest(
    session:     *SessionContext,
    httpRequest: *HttpRequest
): Status {

    var fileResult = OpenFileInfo(
        this.rootPath,
        this.config.publicServerPath,
        httpRequest.path
    )
    if(fileResult.status != Status.OK) {
        return fileResult.status
    }

    session.file       = fileResult.fd
    session.fileOffset = 0

    var response = &session.response
    response.status     = 200
    response.type       = ResponseType.FILE
    response.fileHandle = fileResult.fd
    response.fileSize   = fileResult.fileSize as (usize)

    var mime = this.server.mime.getMimeType(httpRequest.path)
    if(!mime.empty()) {
        response.addHeader($"Content-Type", mime)
    }

    var elapsed = SystemTimeMSec() - session.lastRequestTime
    Info("%s %.*s %d %.0fms\n",
        HttpMethodAsStr(httpRequest.method),
        httpRequest.path.length, httpRequest.path.buffer,
        response.status,
        elapsed
    )

    return this.queueSend(session)
}

internal func (this: *WorkerThread) handleWebSocketFrame(
    session:   *SessionContext,
    bytesRead: i32
): Status {

    var connection = &session.connection
    var readBuffer = &connection.readBuffer

    readBuffer.length += bytesRead

    var frame = Frame{}
    var status = frame.parseHeader(readBuffer)
    if(status != Status.OK) {
        return Status.ERROR_WEB_SOCKET_FRAME
    }

    if(this.config.maxHttpBodySizeInBytes > 0 &&
       frame.payloadLength > this.config.maxHttpBodySizeInBytes
    ) {
        return Status.ERROR_INVALID_BODY_EXCEEDED_LIMIT
    }

    status = frame.parsePayload(readBuffer)
    if(status != Status.OK) {
        if(status == Status.ERROR_WEB_SOCKET_FRAME_LENGTH) {
            if((readBuffer.capacity - frame.offset) < frame.payloadLength) {
                var neededSpace = frame.payloadLength - readBuffer.capacity
                readBuffer.reserve(readBuffer.capacity + neededSpace as (i32))
                Error("TODO: Grow buffer!\n")
                exit(1)
                return Status.ERROR_OUT_OF_MEMORY
            }
            return Status.PARTIAL_WEB_SOCKET_DISPATCHING_READ
        }
        return Status.ERROR_WEB_SOCKET_FRAME
    }

    defer readBuffer.clear()

    if(session.socketHandler.callback) {
        if(!session.socketHandler.callback(&session.socketSession, frame)) {
            return Status.ERROR_WEB_SOCKET_HANDLE_FRAME_ERROR
        }
    }

    if(frame.opcode == Opcode.CLOSE) {
        return Status.WEB_SOCKET_CLOSED
    }

    return Status.OK
}

internal func (this: *WorkerThread) checkTimeouts() {
    var timeout = this.config.keepAliveTimeoutInSec
    const currentTime = SystemTimeMSec()

    for(var i = 0; i < this.sessions.pool.length; i+=1) {
        var context = this.sessions.get(i)
        if(context.inUse && context.connection.isConnected()) {
            var sessionTimeout = timeout
            if(context.isWebSocket || context.isSse) {
                sessionTimeout = 90
            }

            if(context.lastRequestTime + sessionTimeout < currentTime) {
                Debug("Timeout for socket: %d (index: %d)\n",
                    context.connection.handle(), context.index)
                this.closeSession(context)
            }
        }
    }

    this.rearmTimeout()
}
